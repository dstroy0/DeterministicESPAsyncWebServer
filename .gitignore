.pio
.vscode/
docs/html
# Sphinx site build artifacts (generated from docs/Doxyfile XML + docs/sphinx sources)
docs/sphinx/_build/
docs/sphinx/xml/
# Python (asset generator tooling)
__pycache__/
*.pyc
# Generated C/C++ compilation database - the root copy is the machine-specific scan
# copy (@ROOT@ expanded), regenerated in CI by tools/sonar/gen_compiledb.sh. The
# host-independent baseline test/compile_commands.json IS committed (affected runs
# overlay only the changed envs onto it), so un-ignore it.
compile_commands.json
!test/compile_commands.json
compiledb_frags/
# Instrumented build dir + per-env report fragments (regenerated by tools/sonar/gen_coverage.sh).
# test/coverage.xml itself is COMMITTED and updated incrementally by the Test & Analyze workflow, so
# only ignore a stray root-level coverage.xml here, not the tracked one under test/.
/coverage.xml
coverage_reports/
.pio_cov/
.pio_cov_wsl/
docs/favicons/dist/
